3 31.7653 17.5996 32 16 32 C 7.16344 32 0 24.8366 0 16 C 0 7.16344 7.16344 =
0 16 0 Z"); }

.gb_C .gb_Z { display: block; }

.tWhrgb .gb_Z { bottom: 2px; }

.gb_Wc { background: rgba(60, 64, 67, 0.9); border-radius: 4px; color: rgb(=
255, 255, 255); font: 500 12px / 16px Roboto, arial, sans-serif; letter-spa=
cing: 0.8px; margin-top: 4px; min-height: 14px; padding: 4px 8px; position:=
 absolute; outline: transparent solid 1px; user-select: text; z-index: 1000=
; -webkit-font-smoothing: antialiased; }

.gb_Xc, .gb_Zc { text-align: left; }

.gb_Zc > * { color: rgb(196, 199, 197); line-height: 16px; }

.gb_Zc div:first-child { color: white; }

.gb_C { border-radius: 50%; }

.gb_C::before { background: var(--gm3-sys-color-on-surface-variant,#444746)=
; border-radius: 100px; content: ""; height: 100%; left: 0px; opacity: 0; p=
osition: absolute; top: 0px; transition: opacity 0.3s ease-out; width: 100%=
; }

.gb_K .gb_C::before { background: var(--gm3-sys-color-on-surface-variant,#c=
4c7c5); }

.gb_C:hover { background-color: rgba(60, 64, 67, 0.08); }

.gb_C:focus::before, .gb_C:focus:hover::before { opacity: 0.12; }

.gb_C:active::before { opacity: 0.16; }

.gb_C:hover::before { opacity: 0.08; }

.gb_C:hover[aria-expanded=3D"true"]::before, .gb_C[aria-expanded=3D"true"]:=
:before { opacity: 0.16; }

.gb_C:focus-visible { outline-style: solid; outline-width: 1px; outline-off=
set: 0px; outline-color: var(--gm3-sys-color-primary,#0b57d0); }

.gb_K .gb_C:focus-visible { outline-color: var(--gm3-sys-color-primary,#a8c=
7fa); }

.gb_E { position: absolute; pointer-events: none; top: 16px; right: 14px; d=
isplay: flex; -webkit-box-pack: center; justify-content: center; -webkit-bo=
x-align: center; align-items: center; background-color: rgb(179, 38, 30); c=
olor: rgb(255, 255, 255); border-radius: 100px; height: 14px; font-family: =
"Google Sans"; font-size: 11px; font-weight: 500; line-height: 16px; paddin=
g: 2px; transform: translate(50%, -50%); z-index: 1; }

.gb_F { margin: 4px; }

.gb_K .gb_E { background-color: rgb(242, 184, 181); color: rgb(66, 4, 0); }

.gb_S[aria-expanded=3D"true"] { background-color: rgba(60, 64, 67, 0.1); }

.gb_S:focus-visible { outline: rgb(65, 106, 207) solid 1px; outline-offset:=
 0px; }

.gb_K .gb_S[aria-expanded=3D"true"] { background-color: rgba(232, 234, 237,=
 0.1); }

.gb_K .gb_S:focus-visible { outline-color: rgb(184, 205, 247); }

@-webkit-keyframes focus-animation-2px {=20
  0% { outline-color: transparent; outline-offset: 0px; outline-width: 0px;=
 }
  100% { outline-offset: 2px; outline-width: 1px; }
}

@keyframes focus-animation-2px {=20
  0% { outline-color: transparent; outline-offset: 0px; outline-width: 0px;=
 }
  100% { outline-offset: 2px; outline-width: 1px; }
}

.gb_y .gb_A::before { content: " "; position: absolute; top: 0px; left: 0px=
; width: 100%; height: 100%; opacity: 0; border-radius: 100px; background: =
var(--gm3-sys-color-on-primary,#fff); transition: opacity 0.5s ease-out; }

.gb_y .gb_A:hover { cursor: pointer; box-shadow: rgba(0, 0, 0, 0.3) 0px 1px=
 2px 0px, rgba(0, 0, 0, 0.15) 0px 1px 3px 1px; }

.gb_y .gb_A:hover::before { opacity: 0.08; }

.gb_y .gb_A:active::before, .gb_y .gb_A:active:focus::before { opacity: 0.1=
2; }

.gb_y .gb_A:active, .gb_y .gb_A:active:focus { box-shadow: none; }

.gb_y .gb_A:focus-visible::before { opacity: 0.12; }

.gb_y .gb_A:focus-visible { box-shadow: none; }

.gb_y .gb_A:focus-visible { outline-style: solid; outline-color: var(--gm3-=
sys-color-primary,#0b57d0); animation: 0.3s ease-in-out 0s 1 normal forward=
s running focus-animation-2px; }

@media (forced-colors: active) {
  .gb_y .gb_A { border-width: 1px; border-style: solid; border-image: initi=
al; border-color: var(--gm3-sys-color-outline,#747775); }
  .gb_y .gb_A:focus-visible { outline: transparent solid 2px; }
}

.gb_y.gb_K .gb_A::before { background: var(--gm3-sys-color-on-secondary-fix=
ed,#001d35); }

.gb_y.gb_K .gb_A:focus-visible { outline-color: var(--gm3-sys-color-seconda=
ry-fixed,#c2e7ff); }

@media (forced-colors: active) {
  .gb_y.gb_K .gb_A { border-color: var(--gm3-sys-color-outline,#8e918f); }
}

.gb_B { border-radius: 50%; }

.gb_B:hover { background: rgba(68, 71, 70, 0.08); }

.gb_B:active, .gb_B:focus { background: rgba(68, 71, 70, 0.12); }

.gb_B:focus-visible { outline-color: ; outline-width: 1px; outline-style: s=
olid; outline-offset: -1px; }

