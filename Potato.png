  0% { opacity: 0; }
  100% { opacity: 1; }
}

.gb_U { animation: 0.25s ease-in 0s 1 normal none running apd-ring-fade-in;=
 }

.gb_Ma { background: none; border: 1px solid transparent; border-radius: 50=
%; box-sizing: border-box; cursor: pointer; height: 40px; margin: 8px; outl=
ine: none; padding: 1px; position: absolute; right: 0px; top: 0px; width: 4=
0px; }

.gb_Ma:hover { background-color: rgba(68, 71, 70, 0.08); }

.gb_Ma:active, .gb_Ma:focus { background-color: rgba(68, 71, 70, 0.12); }

