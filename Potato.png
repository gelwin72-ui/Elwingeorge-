2); }

.gb_K .gb_B:focus-visible { outline-color: ; outline-width: 1px; outline-st=
yle: solid; outline-offset: -1px; }

.gb_B .gb_T { display: block; }

.gb_C::after { content: ""; position: absolute; inset: -4px; }

@-webkit-keyframes apd-ring-fade-in {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

