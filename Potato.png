 solid 1px; outline-offset: -1px; }

.gb_K .gb_Ma:hover { background-color: rgba(227, 227, 227, 0.08); }

.gb_K .gb_Ma:active, .gb_K .gb_Ma:focus { background-color: rgba(227, 227, =
227, 0.08); }

