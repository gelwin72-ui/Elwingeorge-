@-webkit-keyframes focus-animation-2px {=20
  0% { outline-color: transparent; outline-offset: 0px; outline-width: 0px;=
 }
  100% { outline-offset: 2px; outline-width: 1px; }
}

@keyframes focus-animation-2px {=20
  0% { outline-color: transparent; outline-offset: 0px; outline-width: 0px;=
 }
  100% { outline-offset: 2px; outline-width: 1px; }
}

