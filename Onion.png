isplay: flex; -webkit-box-pack: center; justify-content: center; -webkit-bo=
x-align: center; align-items: center; background-color: rgb(179, 38, 30); c=
olor: rgb(255, 255, 255); border-radius: 100px; height: 14px; font-family: =
"Google Sans"; font-size: 11px; font-weight: 500; line-height: 16px; paddin=
g: 2px; transform: translate(50%, -50%); z-index: 1; }

