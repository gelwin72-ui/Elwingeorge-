@charset "utf-8";

.gb_Z { border-radius: 50%; bottom: 2px; height: 18px; position: absolute; =
right: 0px; width: 18px; }

.gb_Ra { border-radius: 50%; box-shadow: rgba(60, 64, 67, 0.3) 0px 1px 2px =
0px, rgba(60, 64, 67, 0.15) 0px 1px 3px 1px; margin: 2px; }

.gb_Sa { fill: rgb(249, 171, 0); }

.gb_K .gb_Sa { fill: rgb(253, 214, 99); }

.gb_Ta > .gb_Sa { fill: rgb(217, 48, 37); }

.gb_K .gb_Ta > .gb_Sa { fill: rgb(242, 139, 130); }

.gb_Ta > .gb_Ua { fill: white; }

.gb_K .gb_Ta > .gb_Ua, .gb_Ua { fill: rgb(32, 33, 36); }

.gb_Va { clip-path: path("M 16 0 C 24.8366 0 32 7.16344 32 16 C 32 16.4964 =
