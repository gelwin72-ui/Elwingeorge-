ize: 40px; overflow-wrap: anywhere; overflow: hidden; padding-block: var(--=
gm3-tooltip-plain-container-padding-block,4px); padding-inline: 8px; word-b=
reak: normal; max-block-size: var(--gm3-tooltip-plain-container-max-block-s=
ize,40vh); }

